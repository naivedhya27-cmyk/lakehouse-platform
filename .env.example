# LakehousePlatform Environment Variables
# Copy to .env and fill in values

# Application
APP_NAME=LakehousePlatform
DEBUG=false
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://lakehouse:lakehouse@localhost:5432/lakehouse

# Redis
REDIS_URL=redis://localhost:6379

# Object Storage (S3/MinIO)
STORAGE_TYPE=s3
STORAGE_ROOT=s3://lakehouse-data
AWS_ACCESS_KEY_ID=lakehouse
AWS_SECRET_ACCESS_KEY=lakehouse123
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000  # MinIO endpoint (remove for real S3)

# GCS (uncomment for Google Cloud)
# STORAGE_TYPE=gcs
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# STORAGE_ROOT=gs://your-bucket/lakehouse

# Azure (uncomment for Azure)
# STORAGE_TYPE=azure
# AZURE_STORAGE_ACCOUNT_NAME=youraccount
# AZURE_STORAGE_ACCOUNT_KEY=yourkey
# STORAGE_ROOT=abfs://container@account.dfs.core.windows.net/lakehouse

# Spark
SPARK_MASTER=spark://localhost:7077
SPARK_IMAGE=bitnami/spark:3.5

# Trino
TRINO_HOST=localhost
TRINO_PORT=8080

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Keycloak
KEYCLOAK_URL=http://localhost:8082
KEYCLOAK_REALM=lakehouse
KEYCLOAK_CLIENT_ID=lakehouse-api
KEYCLOAK_CLIENT_SECRET=your-client-secret
